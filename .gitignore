# Maven build output
target/

# Compiled JARs — built by start.sh, never committed
greenplum-ai-agent-*.jar

# IDE and OS files
.idea/
*.iml
.classpath
.project
.settings/
.DS_Store
*.swp
*.swo

# Runtime files
agent.pid
*.pid

# Log files
*.log
stdout.log

# User data directory — contains PIN hashes, API keys, session JSON, chat history
# NEVER commit this directory
users/

# Admin configuration
global-prompt.txt

# Sensitive credential and config files
agent-config.properties
agent-credential.txt

# Memory / cache
*memory.json
